# LLM Proxy: all LLM requests route through aura-router (handles billing automatically)
AURA_ROUTER_URL=https://aura-router.onrender.com

# Z-Billing: credit purchases and balance UI
Z_BILLING_URL=https://z-billing.onrender.com

# Optional: GitHub App (for repo linking)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_SLUG=

# Optional: aura-network (shared backend for orgs, projects sync). Leave unset for local-only.
# Also sourced by the marketing `/feedback` page's same-origin pass-through
# (aura-os-server's `GET /api/public/feedback`); the browser no longer reads
# this URL directly.
# AURA_NETWORK_URL=https://aura-network.onrender.com
# AURA_NETWORK_AUTH_TOKEN=
# AURA_NETWORK_INTERNAL_TOKEN=

# Optional: dedicated aura-network URL for the Feedback app only. Leave this
# unset in normal dev/prod setups so Feedback shares AURA_NETWORK_URL.
# Set it only when you intentionally want /api/feedback/* and the
# marketing /api/public/feedback pass-through to target a different
# aura-network deployment for rollout testing.
# AURA_NETWORK_FEEDBACK_URL=https://your-feedback-network-host.example.com

# Optional: aura-storage (execution data store). Leave unset to skip remote storage.
# AURA_STORAGE_URL=https://aura-storage.onrender.com
# AURA_STORAGE_INTERNAL_TOKEN=     # Must match INTERNAL_SERVICE_TOKEN on aura-storage (for executor/scheduler)

# Optional: aura-integrations (encrypted API key storage). Required for secret-backed org integrations.
# AURA_INTEGRATIONS_URL=https://aura-integrations.onrender.com
# AURA_INTEGRATIONS_INTERNAL_TOKEN=   # optional; only for legacy internal-service routes

# Optional: JWT issuer and JWKS URL for the auth provider (e.g. Zero). Single source of truth:
# when running Orbit with Aura, set Orbit's TRUSTED_JWT_ISSUER and TRUSTED_JWT_JWKS_URL to
# these same values (or use scripts/run-orbit-with-env.sh to start Orbit with them).
# GET /api/auth/jwt-issuer returns these from the current session for easy Orbit setup.
# ZERO_JWT_ISSUER=https://zosapi.zero.tech
# ZERO_JWT_JWKS_URL=https://zosapi.zero.tech/.well-known/jwks.json

# Optional: Orbit is a third-party standalone service for Git/repo hosting.
# Set ORBIT_BASE_URL to the Orbit service URL (and port if needed, e.g. http://localhost:PORT).
# Aura does not run Orbit; it only connects to it as a client. Omit to disable Orbit features.
# When set, new projects with an Orbit repo will auto-create the repo via POST /v1/repos (JWT auth).
# For Orbit to accept Aura's token, set Orbit's TRUSTED_JWT_ISSUER and TRUSTED_JWT_JWKS_URL
# to the same values as ZERO_JWT_ISSUER and ZERO_JWT_JWKS_URL above (see Orbit .env.example).
# Use HTTPS for Orbit in production.
# ORBIT_BASE_URL=https://orbit.your-domain.com

# Public URL the aura-os-server advertises to itself. Used to stamp
# cross-agent tool callbacks (send_to_agent, spawn_agent, etc.) so the
# harness — which runs in a separate process/host on prod (e.g. aura-swarm
# on Render) — can reach back in. Required in any deployment where the
# harness does not share loopback with the server; without it the server
# falls back to http://AURA_SERVER_HOST:AURA_SERVER_PORT and tool calls
# fail with "external tool callback unreachable: http://127.0.0.1:...".
# The server reads AURA_SERVER_BASE_URL first, then falls back to
# VITE_API_URL — which the Vite build already consumes — so a single
# Render env var named VITE_API_URL is enough for both the frontend
# bundle and the server self-callback URL. Only set
# AURA_SERVER_BASE_URL explicitly when the frontend and backend must
# advertise different public URLs. Local dev can leave both unset.
# AURA_SERVER_BASE_URL=https://your-aura-os-host.example.com
# VITE_API_URL=https://your-aura-os-host.example.com

# Harness: agent sessions are routed automatically based on the agent's machine_type.
# "local" agents connect to the local harness; all others route through aura-swarm.
# On startup, if nothing is listening at LOCAL_HARNESS_URL, the server will try to
# auto-spawn the harness from AURA_HARNESS_DIR (or ../aura-harness) via `cargo run`.
SWARM_BASE_URL=http://localhost:8080
LOCAL_HARNESS_URL=http://localhost:8080
# AURA_HARNESS_DIR=../aura-harness

# Optional: support/privacy links shown in app settings for desktop + mobile.
# Vite reads these from the interface environment when building/running the UI.
# VITE_PRIVACY_POLICY_URL=https://your-domain.example.com/privacy
# VITE_SUPPORT_URL=https://your-domain.example.com/support

# Disable Phase 3/5 autonomous task decomposition and shaped retries.
# AURA_AUTO_DECOMPOSE_DISABLED=1

# Disable Phase 6 live closed-loop heuristics. When set, the dev-loop
# forwarder will NOT re-run aura_run_heuristics against the in-progress
# run bundle, and no `heuristic_finding` domain events are broadcast.
# Phase 3 post-failure remediation is unaffected.
# AURA_LIVE_HEURISTICS_DISABLED=1

# Optional: Anthropic key for changelog writing and changelog media planning.
# ANTHROPIC_API_KEY=

# Optional: Browser Use Cloud for changelog media capture.
# Browser Use is only called after Anthropic selects desktop visual candidates.
# BROWSER_USE_API_KEY=
# BROWSER_USE_MODEL=claude-opus-4.6
# Frontend URL Browser Use opens. API URL is optional and only needed when the
# deployed frontend and aura-os-server live on different hosts.
# AURA_DEMO_SCREENSHOT_BASE_URL=https://your-preview-host.example.com
# AURA_DEMO_SCREENSHOT_API_URL=https://your-api-host.example.com
# AURA_CHANGELOG_CAPTURE_SECRET=
# Optional: OpenAI key for the branding stage after a real screenshot passes proof gates.
# OPENAI_API_KEY=
# Optional: allow extra dev hosts when capturing through a tunnel.
# Defaults already include .trycloudflare.com, localhost, and 127.0.0.1.
# AURA_DEV_ALLOWED_HOSTS=.trycloudflare.com,localhost,127.0.0.1
# Optional: force-enable the screenshot bridge in non-dev UI builds.
# The runner already injects a runtime flag for seeded capture sessions, so
# this is only needed if you want the bridge always on for a deployed build.
# VITE_ENABLE_SCREENSHOT_BRIDGE=1
