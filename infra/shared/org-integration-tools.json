[
  {
    "name": "list_org_integrations",
    "description": "List saved org integrations that Aura OS can use for shared tools or runtime auth.",
    "promptSignature": "list_org_integrations(provider?)",
    "inputSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "description": "Optional provider filter such as github, linear, slack, or notion."
        }
      }
    }
  },
  {
    "name": "generate_image",
    "description": "Generate an image from a text prompt using the configured image model. Returns the hosted image URL and artifact metadata. Use this whenever the user asks to create, draw, render, or generate an image.",
    "promptSignature": "generate_image(prompt, model?, size?)",
    "inputSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Text description of the image to generate."
        },
        "model": {
          "type": "string",
          "description": "Image model id. Defaults to gpt-image-2.",
          "enum": [
            "gpt-image-2",
            "gpt-image-1",
            "dall-e-3",
            "dall-e-2",
            "gemini-nano-banana"
          ]
        },
        "size": {
          "type": "string",
          "description": "Optional WxH size hint (e.g. 1024x1024, 1792x1024)."
        }
      },
      "required": ["prompt"]
    }
  },
  {
    "name": "generate_3d_model",
    "description": "Generate a 3D model from an image URL or image data URI using the configured 3D generation pipeline. Returns the hosted GLB URL and artifact metadata. Use this whenever the user asks to create, render, or generate a 3D model.",
    "promptSignature": "generate_3d_model(image_url, prompt?, project_id?, parent_id?)",
    "inputSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image_url": {
          "type": "string",
          "description": "Source image URL or data URI to convert into a 3D model."
        },
        "prompt": {
          "type": "string",
          "description": "Optional text prompt or guidance for the 3D model."
        },
        "project_id": {
          "type": "string",
          "description": "Optional project id for artifact storage."
        },
        "parent_id": {
          "type": "string",
          "description": "Optional source image artifact id to link the generated model to."
        }
      },
      "required": ["image_url"]
    }
  },
