[
  {
    "id": "desktop-login-screen",
    "suite": "smoke",
    "kind": "browser_core",
    "title": "Desktop login screen shows the login form",
    "devices": ["eval-desktop-chromium"],
    "bootstrap": "guest",
    "steps": [
      {
        "label": "open_login",
        "navigate": "/login",
        "expect": {
          "visibleRoles": [
            { "role": "button", "name": "Sign In", "exact": true }
          ]
        }
      }
    ]
  },
  {
    "id": "mobile-login-screen",
    "suite": "smoke",
    "kind": "browser_core",
    "title": "Mobile login screen shows the sign in form",
    "devices": [
      "eval-mobile-chromium",
      "eval-mobile-webkit"
    ],
    "bootstrap": "guest",
    "steps": [
      {
        "label": "open_login",
        "navigate": "/login",
        "expect": {
          "visibleRoles": [
            { "role": "button", "name": "Sign In", "exact": true }
          ]
        }
      }
    ]
  },
  {
    "id": "desktop-project-shell",
    "suite": "smoke",
    "kind": "browser_core",
    "title": "Desktop project shell loads the project explorer and execution view",
    "devices": ["eval-desktop-chromium"],
    "bootstrap": "mock_authenticated_app",
    "steps": [
      {
        "label": "open_projects",
        "navigate": "/projects",
        "expect": {
          "urlMatches": "/projects$",
          "visibleRoles": [
            { "role": "button", "name": "Demo Project" }
          ]
        }
      },
      {
        "label": "open_execution",
        "navigate": "/projects/proj-1/work",
        "expect": {
          "visibleRoles": [
            { "role": "button", "name": "Demo Project" },
            { "role": "button", "name": "Plans", "exact": true },
            { "role": "button", "name": "Tasks", "exact": true }
          ]
        }
      },
      {
        "label": "open_stats_from_overflow",
        "action": {
          "clickRole": { "role": "button", "name": "More actions", "exact": true }
        },
        "expect": {
          "visibleRoles": [
            { "role": "menuitem", "name": "Stats", "exact": true }
          ]
        }
      }
    ]
  }
]
